---
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">["data"];

const { title, pubDate, updatedDate, heroImage } = Astro.props;
---

<article
    class="mt-8 prose prose-invert max-w-none
        prose-p:text-[#c2bdb6] prose-p:font-light prose-p:leading-relaxed prose-p:text-[15px]
        prose-headings:text-[#e8e4de] prose-headings:font-semibold prose-headings:tracking-tight
        prose-h2:text-[18px] prose-h3:text-[16px]
        prose-strong:text-[#e8e4de] prose-strong:font-medium
        prose-a:text-[#8a8580] prose-a:no-underline hover:prose-a:text-[#c2bdb6]
        prose-code:font-mono prose-code:text-[#8a8580] prose-code:text-[13px] prose-code:bg-transparent prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-white/[0.04] prose-pre:border prose-pre:border-white/[0.08] prose-pre:rounded-[10px] prose-pre:font-mono
        prose-blockquote:border-white/[0.12] prose-blockquote:text-[#7a7672]
        prose-hr:border-white/[0.06]"
>
    <slot />
</article>
