---
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">["data"];

const { title, pubDate, updatedDate, heroImage } = Astro.props;
---

<article
    class="mt-8 prose prose-invert max-w-none
        prose-p:text-ink-3 prose-p:font-light prose-p:leading-relaxed prose-p:text-[15px]
        prose-headings:text-ink-2 prose-headings:font-semibold prose-headings:tracking-tight
        prose-h2:text-[18px] prose-h3:text-[16px]
        prose-strong:text-ink-2 prose-strong:font-medium
        prose-a:text-accent prose-a:no-underline hover:prose-a:text-accent-light
        prose-code:font-mono prose-code:text-ink-4 prose-code:text-[13px] prose-code:bg-transparent prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-rim-1 prose-pre:border prose-pre:border-rim-5 prose-pre:rounded-[10px] prose-pre:font-mono
        prose-blockquote:border-rim-6 prose-blockquote:text-ink-5
        prose-hr:border-rim-3"
>
    <slot />
</article>
