---
interface Props {
    label: string;
    href: string;
    value: string;
}

const { label, href, value } = Astro.props;
---

<div class="flex items-center justify-between py-3">
    <span class="text-sm text-ink-3">{label}</span>
    <a
        href={href}
        class="font-mono text-xs text-ink-8 hover:text-accent transition-colors"
    >
        {value}
    </a>
</div>
