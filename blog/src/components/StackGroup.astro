---
interface Props {
    category: string;
    items: string[];
}

const { category, items } = Astro.props;
---

<div class="flex flex-col gap-2">
    <span class="font-mono text-[10px] text-ink-8 tracking-[0.08em] uppercase">
        {category}
    </span>
    <div class="flex flex-wrap gap-2">
        {
            items.map((item) => (
                <span class="font-mono text-xs text-ink-4 bg-rim-2 border border-rim-5 rounded-md px-2.5 py-1">
                    {item}
                </span>
            ))
        }
    </div>
</div>
