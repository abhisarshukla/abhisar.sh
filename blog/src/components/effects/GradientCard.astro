---
export interface Props {
    title: string;
    description?: string;
    circleSize?: number;
    class?: string;
    footer?: string;
    href?: string;
}

const {
    title,
    description,
    circleSize = 400,
    class: className,
    href,
    footer,
} = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
    href={href}
    class="gradient-card group relative transform-gpu overflow-hidden rounded-[14px] bg-rim-2 border border-rim-4 p-2 transition-all hover:border-rim-7 hover:bg-rim-4 active:scale-[0.98] block no-underline"
>
    <div
        class="gradient-circle -translate-x-1/2 -translate-y-1/2 absolute transform-gpu rounded-full transition-transform duration-500 group-hover:scale-[3] opacity-0"
        style={{
            maskImage: `radial-gradient(${circleSize / 2}px circle at center, white, transparent)`,
            width: `${circleSize}px`,
            height: `${circleSize}px`,
            background:
                "linear-gradient(135deg, var(--color-accent-dark), var(--color-accent), var(--color-accent-light), var(--color-accent-mid))",
        }}
    >
    </div>
    <div
        class="absolute inset-px rounded-[13px] bg-base/80"
    >
    </div>
    <slot />
    <div class="relative px-4 pt-4 pb-2">
        <h3 class="font-medium text-base text-ink-2 leading-snug tracking-[-0.01em]">
            {title}
        </h3>
        {
            description && (
                <p class="mt-1.5 text-[13px] font-light text-ink-5 leading-[1.6]">
                    {description}
                </p>
            )
        }
    </div>
    {
        (footer || Astro.slots.has("footer")) && (
            <div class="relative px-4 pb-4 pt-2 border-t border-rim-3">
                {footer && (
                    <div class="font-mono text-[11px] text-ink-7 tracking-[0.03em]">
                        {footer}
                    </div>
                )}
                <slot name="footer" />
            </div>
        )
    }
</Tag>

<script is:inline>
    // Mouse tracking functionality
    function initGradientCard() {
        const cards = document.querySelectorAll(".gradient-card");

        cards.forEach((card) => {
            const circle = card.querySelector(".gradient-circle");

            card.addEventListener("mousemove", (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                if (circle) {
                    circle.style.left = `${x}px`;
                    circle.style.top = `${y}px`;
                    circle.style.opacity = "1";
                }
            });

            card.addEventListener("mouseleave", () => {
                if (circle) {
                    circle.style.opacity = "0";
                }
            });
        });
    }

    // Initialize on page load
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGradientCard);
    } else {
        initGradientCard();
    }

    // Re-initialize for dynamic content (useful for client-side navigation)
    document.addEventListener("astro:page-load", initGradientCard);
</script>
