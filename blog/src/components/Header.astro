---
import { SITE_TITLE } from "../consts";
---

<header>
	<nav class="fixed w-full top-0 z-50 border-b border-rim-4 bg-base/90 backdrop-blur-sm">
		<div class="max-w-[680px] mx-auto flex items-center justify-between px-5 md:px-12 py-[18px]">
			<a
				href="/"
				class="font-mono text-sm font-medium text-ink-2 tracking-tight hover:text-white transition-colors"
			>
				{SITE_TITLE}
			</a>

			<!-- Desktop links -->
			<div class="hidden md:flex items-center gap-7">
				<a
					href="/blog"
					class="text-xs text-ink-6 hover:text-accent transition-colors tracking-wide"
				>
					blog
				</a>
				<a
					href="/about"
					class="text-xs text-ink-6 hover:text-accent transition-colors tracking-wide"
				>
					about
				</a>
			</div>

			<!-- Mobile hamburger -->
			<button
				id="menu-toggle"
				class="md:hidden flex flex-col gap-[5px] items-end py-1"
				aria-label="Toggle menu"
			>
				<span class="block w-[18px] h-px bg-ink-7"></span>
				<span class="block w-[13px] h-px bg-ink-7"></span>
			</button>
		</div>

		<!-- Mobile menu -->
		<div id="mobile-menu" class="hidden md:hidden border-t border-rim-3">
			<div class="max-w-[680px] mx-auto px-5 py-4 flex flex-col gap-3">
				<a
					href="/blog"
					class="text-sm text-ink-3 hover:text-ink-2 transition-colors"
				>
					blog
				</a>
				<a
					href="/about"
					class="text-sm text-ink-3 hover:text-ink-2 transition-colors"
				>
					about
				</a>
			</div>
		</div>
	</nav>
</header>

<script>
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");

	const close = () => menu?.classList.add("hidden");

	toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));

	// Close when a nav link is tapped
	menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));

	// Close when restored from bfcache (browser back/forward)
	window.addEventListener("pageshow", (e) => { if (e.persisted) close(); });

	// Close on Astro client-side navigation
	document.addEventListener("astro:page-load", close);
</script>
