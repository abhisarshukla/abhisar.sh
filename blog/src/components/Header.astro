---
import { SITE_TITLE } from "../consts";
---

<header>
	<nav class="fixed w-full top-0 z-50 border-b border-white/[0.07] bg-[#131211]/90 backdrop-blur-sm">
		<div class="max-w-[680px] mx-auto flex items-center justify-between px-5 md:px-12 py-[18px]">
			<a
				href="/"
				class="font-mono text-sm font-medium text-[#e8e4de] tracking-tight hover:text-white transition-colors"
			>
				{SITE_TITLE}
			</a>

			<!-- Desktop links -->
			<div class="hidden md:flex items-center gap-7">
				<a
					href="/blog"
					class="text-xs text-[#6b6762] hover:text-[#c2bdb6] transition-colors tracking-wide"
				>
					blog
				</a>
				<a
					href="/about"
					class="text-xs text-[#6b6762] hover:text-[#c2bdb6] transition-colors tracking-wide"
				>
					about
				</a>
			</div>

			<!-- Mobile hamburger -->
			<button
				id="menu-toggle"
				class="md:hidden flex flex-col gap-[5px] items-end py-1"
				aria-label="Toggle menu"
			>
				<span class="block w-[18px] h-px bg-[#635f5c]"></span>
				<span class="block w-[13px] h-px bg-[#635f5c]"></span>
			</button>
		</div>

		<!-- Mobile menu -->
		<div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.06]">
			<div class="max-w-[680px] mx-auto px-5 py-4 flex flex-col gap-3">
				<a
					href="/blog"
					class="text-sm text-[#c2bdb6] hover:text-[#e8e4de] transition-colors"
				>
					blog
				</a>
				<a
					href="/about"
					class="text-sm text-[#c2bdb6] hover:text-[#e8e4de] transition-colors"
				>
					about
				</a>
			</div>
		</div>
	</nav>
</header>

<script>
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");
	toggle?.addEventListener("click", () => {
		menu?.classList.toggle("hidden");
	});
</script>
